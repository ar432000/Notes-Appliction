<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Application1.ViewModels"
    x:Class="Application1.MainPage">

    <ContentPage.Resources>
        <StyleSheet Source="/Resources/Styles/styles.css" />
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <viewModels:NotesViewModel />
    </ContentPage.BindingContext>

    <Grid
        Padding="20"
        RowDefinitions="Auto,*">

        <!-- TOP SECTION -->
        <VerticalStackLayout
            Grid.Row="0"
            Spacing="15">

            <Label
                Text="Simple Notes App"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                StyleClass="titleLabel" />

            <Entry
                Placeholder="Enter Note Title"
                Text="{Binding NoteTitle, Mode=TwoWay}"
                StyleClass="inputEntry" />

            <Editor
                Placeholder="Enter Note Description"
                HeightRequest="120"
                AutoSize="Disabled"
                VerticalOptions="Start"
                Text="{Binding NoteDescription, Mode=TwoWay}"
                StyleClass="inputEntry" />

            <Button
                Text="{Binding ButtonText}"
                Command="{Binding AddOrUpdateNoteCommand}"
                StyleClass="addButton" />

        </VerticalStackLayout>

        <!-- NOTES CONTAINER -->
        <Frame
            Grid.Row="1"
            IsVisible="{Binding HasNotes}"
            Margin="0,20,0,0"
            Padding="10"
            BorderColor="LightGray"
            CornerRadius="15"
            HasShadow="True">

            <CollectionView
                ItemsSource="{Binding Notes}">

                <CollectionView.ItemTemplate>

                    <DataTemplate>

                        <Frame
                            StyleClass="noteFrame"
                            Margin="0,0,0,15">

                            <VerticalStackLayout Spacing="8">

                                <Label
                                    Text="{Binding Title}"
                                    StyleClass="noteTitle" />

                                <!-- DESCRIPTION -->
                                <FlexLayout
                                    Wrap="Wrap"
                                    Direction="Row"
                                    AlignItems="Center">

                                    <Label
                                        Text="{Binding DescriptionText}"
                                        StyleClass="noteDescription"
                                        LineBreakMode="WordWrap" />

                                    <Button
                                        Text="{Binding MoreLessText}"
                                        FontSize="14"
                                        Padding="0"
                                        Margin="5,0,0,0"
                                        BackgroundColor="Transparent"
                                        TextColor="Blue"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleDescriptionCommand}"
                                        CommandParameter="{Binding .}" />

                                </FlexLayout>

                                <!-- BUTTONS -->
                                <HorizontalStackLayout
                                    Spacing="12"
                                    Margin="0,10,0,0">

                                    <Button
                                        Text="Edit"
                                        StyleClass="editButton"
                                        WidthRequest="120"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditNoteCommand}"
                                        CommandParameter="{Binding .}" />

                                    <Button
                                        Text="Delete"
                                        StyleClass="deleteButton"
                                        WidthRequest="120"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteNoteCommand}"
                                        CommandParameter="{Binding .}" />

                                </HorizontalStackLayout>

                            </VerticalStackLayout>

                        </Frame>

                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

        </Frame>

    </Grid>

</ContentPage>