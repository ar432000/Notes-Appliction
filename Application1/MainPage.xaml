<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Application1.ViewModels"
    x:Class="Application1.MainPage">

    <ContentPage.Resources>
        <StyleSheetExtension Source="/Resources/Styles/styles.css" />
    </ContentPage.Resources>
    
    <ContentPage.BindingContext>
        <viewModels:NotesViewModel/>
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label
                Text="Simple Notes App"
                FontSize="28"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                StyleClass="titleLabel"/>

            <Entry
                Placeholder="Enter Note Title"
                Text="{Binding NoteTitle,Mode=TwoWay}"
                StyleClass="inputEntry"/>

            <Editor
                Placeholder="Enter Note Descriptio"
                HeightRequest="120"
                Text="{Binding NoteDescription,Mode=TwoWay}" 
                StyleClass="inputEntry"/>

            <Button
                Text="Add / Update Note"
                Command="{Binding AddOrUpdateNoteCommand}" 
                StyleClass="addButton"/>

            <CollectionView ItemsSource="{Binding Notes}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame StyleClass="noteFrame">
                            <VerticalStackLayout>

                                <Label
                                    Text="{Binding Title}"
                                    StyleClass="noteTitle"/>

                                <Label
                                    Text="{Binding Description}"
                                    StyleClass="noteDescription"/>

                                <HorizontalStackLayout
                                    Spacing="12"
                                    Margin="0,10,0,0">

                                    <Button
                                        Text="Edit"
                                        StyleClass="editButton"
                                        WidthRequest="120"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditNoteCommand}"
                                        CommandParameter="{Binding .}" />

                                    <Button
                                        Text="Delete"
                                        StyleClass="deleteButton"
                                        WidthRequest="120"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteNoteCommand}"
                                        CommandParameter="{Binding .}" />

                                </HorizontalStackLayout>

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>